{
  "pluginAlias": "HomeBridgeSmartThings",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "required": true,
        "default": "Smartthings Plug (IK)"
      },
      "BaseURL": {
        "title": "Base URL",
        "type": "string",
        "required": true,
        "default": "https://api.smartthings.com/v1/"
      },
      "AccessToken": {
        "title": "Access Token",
        "type": "string",
        "required": true,
        "default": ""
      },
      "WebhookToken": {
        "title": "Webhook Token",
        "type": "string",
        "required": false,
        "default": ""
      },

      "GarageDoorMaxPoll": {
        "title": "Garage Door Max Poll",
        "type": "integer",
        "required": true,
        "default": 40
      },
      "PollLocksSeconds": {
        "title": "Poll Locks (zero = don't poll)",
        "type": "integer",
        "required": false,
        "default": 10
      },
      "PollDoorsSeconds": {
        "title": "Poll Garage Doors (zero = don't poll)",
        "type": "integer",
        "required": false,
        "default": 10
      },
      "PollSensorsSeconds": {
        "title": "Poll Sensors (zero = don't poll)",
        "type": "integer",
        "required": false,
        "default": 5
      },
      "PollSwitchesAndLightsSeconds": {
        "title": "Poll Switches and Lights (zero = don't poll)",
        "type": "integer",
        "required": false,
        "default": 10
      },
      "PollWindowShadesSeconds": {
        "title": "Poll Window Shades (zero = don't poll)",
        "type": "integer",
        "required": false,
        "default": 20
      },
      "ExposeHumiditySensorForAirConditioners": {
        "title": "Expose humidity Sensor for air Conditioners if available.",
        "type": "boolean",
        "required": false,
        "default": false
      },
      "OptionalModeForAirConditioners": {
        "title": "Select what optional mode to use as additional switch in air conditioners.",
        "type": "string",
        "required": false,
        "enum": [
          "Sleep",
          "Speed",
          "WindFree",
          "WindFreeSleep"
        ],
        "default": "None"
      },
      "IgnoreLocations": {
        "title": "Locations to Ignore",
        "type": "array",
        "items": {
          "title": "Location Name",
          "type": "string"
        }
      },
      "IgnoreDevices": {
        "title": "Devices to Ignore",
        "type": "array",
        "items": {
          "title": "Device Name",
          "type": "string"
        }
      },
      "IgnoreDeviceRules": {
        "title": "Device Ignore Rules",
        "description": "Ignore devices by SmartThings metadata. Use * for any characters and ? for one character. All fields in a rule must match; a device is ignored when any rule matches.",
        "type": "array",
        "items": {
          "title": "Ignore Rule",
          "type": "object",
          "minProperties": 1,
          "additionalProperties": false,
          "properties": {
            "label": {
              "title": "Device Label",
              "description": "The user-visible SmartThings device name, for example Hue *",
              "type": "string"
            },
            "name": {
              "title": "Integration Device Name",
              "description": "The name assigned by the device integration",
              "type": "string"
            },
            "manufacturerName": {
              "title": "Manufacturer",
              "description": "For example Signify* or *Hue*",
              "type": "string"
            },
            "type": {
              "title": "Integration Type",
              "description": "For example ENDPOINT_APP for devices supplied by linked cloud integrations",
              "type": "string"
            },
            "installedAppId": {
              "title": "Installed App ID",
              "description": "The installedAppId shared by devices from one linked SmartThings integration",
              "type": "string"
            },
            "deviceId": {
              "title": "Device ID",
              "description": "The unique SmartThings device ID",
              "type": "string"
            }
          }
        }
      },
      "LogDeviceData": {
        "title": "Log SmartThings Device Data",
        "description": "Temporarily log the metadata returned for every SmartThings device. Use this to identify values for Device Ignore Rules, then disable it.",
        "type": "boolean",
        "required": false,
        "default": false
      }
    }
  },
  "form": null,
  "display": null
}
